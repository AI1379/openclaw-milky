{
  "id": "openclaw-milky",
  "channels": ["milky"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "baseURL": { "type": "string", "description": "Milky HTTP API base URL (e.g. http://127.0.0.1:3000)" },
            "token": { "type": "string", "description": "Access token (leave empty if not required)" },
            "enabled": { "type": "boolean", "default": true },
            "connectionKind": { "type": "string", "enum": ["sse", "websocket", "auto"], "default": "websocket", "description": "Event streaming transport" },
            "dmPolicy": { "type": "string", "enum": ["allowlist", "open"], "default": "allowlist" },
            "allowedUserIds": { "type": "array", "items": { "type": "string" }, "default": [], "description": "QQ user IDs allowed to DM the bot" },
            "groupPolicy": { "type": "string", "enum": ["all", "allowlist", "mention"], "default": "all", "description": "Group message policy: 'mention' only responds when @bot, logs others to JSONL" },
            "groupLogDir": { "type": "string", "default": "~/.openclaw/workspace/logs/milky-groups", "description": "Directory for group JSONL logs (mention mode)" },
            "allowedGroups": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Group IDs the bot responds to (when groupPolicy=allowlist)" },
            "autoAcceptFriendRequest": { "type": "boolean", "default": true },
            "autoAcceptGroupInvitation": { "type": "boolean", "default": true },
            "botQQ": { "type": ["number", "null"], "default": null, "description": "Auto-detected, usually no need to set" }
          }
        }
      }
    }
  }
}
